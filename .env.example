# Smart Fish Feeder — Environment Variables
# Copy this to .env and fill in your values

# Django REST backend base URL
API_BASE_URL=https://your-backend.onrender.com/api/v1

# Auth token (if using token-based auth)
# API_AUTH_TOKEN=your_token_here

# Firebase (for V2 push notifications)
# FIREBASE_PROJECT_ID=your_project_id
